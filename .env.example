# Phishing Simulation Platform - Environment Configuration

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development

# ============================================================================
# EMAIL (SMTP) CONFIGURATION
# ============================================================================
# Gmail example:
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# For production, use a dedicated SMTP service like:
# - SendGrid
# - AWS SES
# - Postmark
# - Brevo (formerly Sendinblue)

# ============================================================================
# BASE URL
# ============================================================================
# URL where the platform is hosted (for tracking links)
BASE_URL=http://localhost:8000

# Production example:
# BASE_URL=https://sim.smecyberguard.com

# ============================================================================
# DATABASE
# ============================================================================
# Local SQLite database
LOCAL_DB=./simulation_data.db

# ============================================================================
# TURSO INTEGRATION (Optional - for SMEAgent sync)
# ============================================================================
TURSO_URL=
TURSO_AUTH_TOKEN=
TURSO_SYNC=false

# ============================================================================
# SMEAGENT INTEGRATION (Optional)
# ============================================================================
SMEAGENT_API_URL=https://dashboard.smecyberguard.com/api
SMEAGENT_API_KEY=

# ============================================================================
# ADMIN
# ============================================================================
ADMIN_EMAIL=admin@smecyberguard.com

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
